# =============================================================================
# FuelGrid OS — PRODUCTION config & secret inventory (DigitalOcean Droplet)
# =============================================================================
# COPY this file to `.env` on the droplet, NEXT TO deploy/docker-compose.prod.yml
# and deploy/Caddyfile, then fill in every value. `docker compose` reads it for
# variable interpolation AND the `api` service loads it via `env_file`.
#
#   cp .env.production.example .env && chmod 600 .env   # then edit
#
# NEVER commit the populated .env. Secrets are redacted in API logs/errors by
# the config.Secret type, but the file itself is plaintext on the box — keep it
# 0600, owned by the deploy user.
#
# Legend:
#   [SECRET]    -> a credential; keep out of source control, rotate via the box
#   [CONFIG]    -> non-secret operational config
#   [FAIL-STOP] -> the API refuses to boot outside development if missing/invalid
#
# All env names + fail-stop rules below were confirmed against
# services/api/internal/config/config.go.
# =============================================================================


# -----------------------------------------------------------------------------
# Public hostnames (DNS) — Caddy + ingress
# -----------------------------------------------------------------------------
# [CONFIG] The two public hostnames. Create DNS A records for BOTH pointing at
#          the droplet's public IP BEFORE first boot (Caddy needs them for ACME
#          / Let's Encrypt issuance). WEB_DOMAIN is the app + BFF the browser
#          hits; API_DOMAIN is the public API host (M-Pesa Daraja callback +
#          direct clients). Consumed by deploy/Caddyfile via compose.
WEB_DOMAIN=app.fuelgrid.example
API_DOMAIN=api.fuelgrid.example


# -----------------------------------------------------------------------------
# Container images (GHCR) — overridden by the CD deploy job to the just-built
# sha-<sha> refs. Pin to an immutable :sha-<sha> tag in prod, never :latest.
# -----------------------------------------------------------------------------
# [CONFIG] Owner/repo lowercased. The CD deploy exports these as
#          ghcr.io/<owner>/<repo>-{api,web,migrate}:sha-<commit-sha>.
API_IMAGE=ghcr.io/OWNER/REPO-api:sha-REPLACE_ME
WEB_IMAGE=ghcr.io/OWNER/REPO-web:sha-REPLACE_ME
MIGRATE_IMAGE=ghcr.io/OWNER/REPO-migrate:sha-REPLACE_ME


# -----------------------------------------------------------------------------
# Core API
# -----------------------------------------------------------------------------
# [CONFIG] [FAIL-STOP gate] Selects production validation (https-only CORS +
#          RLS-required DB pool). MUST be exactly "production". The compose
#          `api` service also hard-sets this so a bad .env can't downgrade it.
NODE_ENV=production

# [CONFIG] Listener (the compose api service hard-sets these too). API_PORT must
#          match the image EXPOSE (8080) + the Caddyfile upstream (api:8080).
API_HOST=0.0.0.0
API_PORT=8080

# [CONFIG] Logging.
API_LOG_LEVEL=info
API_LOG_FORMAT=json

# [CONFIG] [FAIL-STOP outside dev] CORS allow-list. Comma-separated. Every entry
#          MUST be an explicit https:// origin (no "*", no http://) or the API
#          refuses to boot. Set it to the WEB public origin.
API_CORS_ALLOWED_ORIGINS=https://app.fuelgrid.example

# [CONFIG] Trusted reverse-proxy hops. Caddy is exactly 1 hop in front of the
#          API, so set 1 to read the real client IP from X-Forwarded-For
#          (AUTH-09). (The compose api service also hard-sets this.)
API_TRUSTED_PROXY_DEPTH=1

# [CONFIG] Graceful shutdown budget.
API_SHUTDOWN_TIMEOUT=15s


# -----------------------------------------------------------------------------
# Database (self-hosted Postgres 16 on the same droplet, private network)
# -----------------------------------------------------------------------------
# [CONFIG]  Postgres bootstrap creds — used to initialise the pgdata volume on
#           first boot AND to build the owner DSN below. POSTGRES_USER is the
#           table OWNER role.
# [SECRET]  POSTGRES_PASSWORD — generate a strong value: `openssl rand -base64 24`.
POSTGRES_USER=fuelgrid
POSTGRES_PASSWORD=CHANGE_ME_STRONG_OWNER_PASSWORD
POSTGRES_DB=fuelgrid

# [SECRET] OWNER DSN — MIGRATIONS ONLY (the one-shot `migrate` service runs
#          golang-migrate `up` as the owner). Reached over the PRIVATE compose
#          network as host `postgres`, so sslmode=disable is correct (there is
#          no sslmode requirement in config.go). Keep ${POSTGRES_PASSWORD} in
#          sync with the value above.
DATABASE_URL=postgres://fuelgrid:CHANGE_ME_STRONG_OWNER_PASSWORD@postgres:5432/fuelgrid?sslmode=disable

# [SECRET] [FAIL-STOP outside dev when DATABASE_URL set] NON-OWNER DSN. The
#          RUNNING API uses this for ALL request-scoped queries so Postgres RLS
#          enforces tenant isolation. MUST be the `fuelgrid_app` role (created by
#          migration 0005_rls.up.sql) and MUST be DISTINCT from DATABASE_URL.
#          0005 creates the role with the WEAK default password 'fuelgrid_app';
#          AFTER the first migrate you MUST rotate it:
#            docker compose -f docker-compose.prod.yml exec postgres \
#              psql -U fuelgrid -c "ALTER ROLE fuelgrid_app PASSWORD '<strong>';"
#          then put that <strong> value here. (See the runbook step (e).)
DATABASE_APP_URL=postgres://fuelgrid_app:CHANGE_ME_STRONG_APP_ROLE_PASSWORD@postgres:5432/fuelgrid?sslmode=disable

# [CONFIG] Pool tuning.
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MIN_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m


# -----------------------------------------------------------------------------
# Redis (self-hosted on the same droplet, private network)
# -----------------------------------------------------------------------------
# [CONFIG] Reached internally as host `redis`. No password (private network,
#          not host-published). Used for sessions, rate limiting, login
#          throttling, scheduler coordination; /readyz pings it.
REDIS_URL=redis://redis:6379/0


# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# [SECRET] [FAIL-STOP path] Pepper mixed (HMAC) into every argon2id password
#          hash AND used for MFA-secret-at-rest. Generate ONCE:
#          `openssl rand -base64 32`. ROTATION INVALIDATES ALL EXISTING PASSWORD
#          HASHES + MFA enrollments — treat as permanent; record it safely.
AUTH_PASSWORD_PEPPER=

# [CONFIG] Session / lockout / reset tuning (defaults are sane).
AUTH_SESSION_TTL=12h
AUTH_REFRESH_TTL=720h
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW=15m
AUTH_LOGIN_LOCK_AFTER=10
AUTH_LOGIN_LOCK_FOR=30m
AUTH_PASSWORD_RESET_TTL=1h
AUTH_PASSWORD_RESET_RATE_LIMIT=10
AUTH_PASSWORD_RESET_RATE_WINDOW=15m

# [CONFIG] Server-side MFA enforcement for privileged roles (SR-M1). Defaults
#          true via the production load path; leave true in prod.
AUTH_ENFORCE_MFA_FOR_PRIVILEGED_ROLES=true

# [SECRET] Platform-admin bearer for POST /api/v1/platform/tenants (tenant
#          provisioning / IaC). Blank DISABLES the route. Set to a long random
#          token in prod: `openssl rand -hex 32`.
PLATFORM_ADMIN_TOKEN=


# -----------------------------------------------------------------------------
# Request throttling / load shedding (defaults are production-tuned)
# -----------------------------------------------------------------------------
# [CONFIG]
API_TENANT_RATE_LIMIT=600
API_TENANT_RATE_WINDOW=1m
API_MAX_INFLIGHT=256
API_HEALTHCHECK_INTERVAL=3s
API_DEFAULT_PAGE_SIZE=50
API_MAX_PAGE_SIZE=200


# -----------------------------------------------------------------------------
# Outbox + background scheduler (defaults are production cadence)
# -----------------------------------------------------------------------------
# [CONFIG]
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=100
SCHEDULER_ENABLED=true
SCHEDULER_REVENUE_COMPUTE_INTERVAL=1h
SCHEDULER_AGING_REFRESH_INTERVAL=1h
SCHEDULER_RISK_DETECT_INTERVAL=30m
SCHEDULER_PROJECTION_INTERVAL=15m
SCHEDULER_OUTBOX_SWEEP_INTERVAL=5m
SCHEDULER_SESSION_CLEANUP_INTERVAL=1h
SCHEDULER_RETENTION_SWEEP_INTERVAL=24h
SCHEDULER_SCHEDULED_REPORTS_INTERVAL=1m
SCHEDULER_SESSION_RETENTION=720h
SCHEDULER_OUTBOX_REQUEUE_AFTER=1h
SCHEDULER_JOB_RUN_RETENTION=720h
SCHEDULER_LOCK_TIMEOUT=10m


# -----------------------------------------------------------------------------
# Transactional email (SMTP) — optional; console no-op driver when SMTP_HOST blank
# -----------------------------------------------------------------------------
# [CONFIG]
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
# [SECRET] SMTP password.
SMTP_PASSWORD=
# [CONFIG] Envelope From + public web origin used to build email links (e.g.
#          password-reset URLs). Set APP_BASE_URL to https://${WEB_DOMAIN}.
SMTP_FROM=no-reply@fuelgrid.example
APP_BASE_URL=https://app.fuelgrid.example


# -----------------------------------------------------------------------------
# M-Pesa (Safaricom Daraja) — optional; disabled no-op (503) when keys unset
# -----------------------------------------------------------------------------
# [SECRET] Daraja API credentials.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
# [CONFIG] Environment selector (sandbox|production).
MPESA_ENV=production
# [CONFIG] Shortcode + STK callback URL (non-secret). The callback MUST be the
#          PUBLIC API host (Daraja calls it from the internet), i.e. via Caddy:
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://api.fuelgrid.example/api/v1/payments/mpesa/callback


# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# [CONFIG] Outbox-lag metric refresh cadence.
METRICS_OBSERVE_INTERVAL=15s

# [CONFIG] [FAIL-STOP when OTEL_EXPORTER=otlp] Tracing exporter: none|stdout|otlp.
#          When "otlp", OTEL_EXPORTER_OTLP_ENDPOINT MUST be a reachable collector
#          (bare host:port or https:// = TLS; http:// = insecure) or the API
#          refuses to boot. Keep "none" until a collector exists.
OTEL_EXPORTER=none
OTEL_SERVICE_NAME=fuelgrid-api
# [SECRET-ish] Collector endpoint (may embed auth). Leave blank unless OTLP on.
OTEL_EXPORTER_OTLP_ENDPOINT=

# [SECRET] Sentry DSN (authorizes event ingestion). Blank disables Sentry.
SENTRY_DSN=
# [CONFIG] Fraction of transactions traced — keep tiny in prod.
SENTRY_TRACES_SAMPLE_RATE=0.05


# -----------------------------------------------------------------------------
# Web app (apps/web) — read by compose for the `web` service
# -----------------------------------------------------------------------------
# NOTE: API_ORIGIN is hard-set to http://api:8080 in the compose `web` service
#       (the internal compose service name — NOT a public URL), so you do NOT
#       set it here. The browser only ever talks to https://${WEB_DOMAIN}.
# [CONFIG] Public, browser-visible metadata (NEXT_PUBLIC_*).
NEXT_PUBLIC_APP_NAME=FuelGrid OS
NEXT_PUBLIC_APP_ENV=production
# [SECRET-ish] Browser Sentry DSN (public but environment-specific).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05


# -----------------------------------------------------------------------------
# Nightly backups (deploy/backup/pg_backup.sh) — optional offsite push
# -----------------------------------------------------------------------------
# [CONFIG] Local rotation: how many days of dumps to keep on the droplet.
BACKUP_KEEP_DAYS=14
# [CONFIG] OPTIONAL DigitalOcean Spaces (s3-compatible) offsite copy. Leave
#          SPACES_BUCKET blank to keep backups local-only. When set, the script
#          pushes via `aws s3 cp --endpoint-url`.
SPACES_BUCKET=
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# [SECRET] Spaces access keys (only needed when SPACES_BUCKET is set).
SPACES_ACCESS_KEY_ID=
SPACES_SECRET_ACCESS_KEY=


# =============================================================================
# GitHub Actions CD secrets — NOT app runtime env. Set under
# Settings -> Secrets and variables -> Actions (or the `production` Environment):
#   DEPLOY_SSH_KEY     [SECRET] private SSH key authorised for the droplet deploy user
#   DEPLOY_HOST        [SECRET] droplet public IP or hostname
#   DEPLOY_USER        [SECRET] deploy user (e.g. `deploy`)
#   DEPLOY_HEALTH_URL  [SECRET] https://${API_DOMAIN}/readyz for the post-deploy smoke gate
# When DEPLOY_SSH_KEY is unset the CD deploy job is a clean no-op (::notice:: + skip);
# likewise the smoke gate no-ops without DEPLOY_HEALTH_URL.
# =============================================================================
