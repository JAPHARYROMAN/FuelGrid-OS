# =============================================================================
# FuelGrid OS — PRODUCTION config & secret inventory
# =============================================================================
# This is a documentation template, NOT a file you deploy. Production never
# reads a .env file: NON-secret values live in the fly.toml [env] blocks
# (services/api/fly.toml, apps/web/fly.toml) and SECRETS are injected via
# `fly secrets set` (stored in Fly's encrypted Vault, redacted in logs by the
# config.Secret type).
#
# Legend:
#   [SECRET]  -> set via `fly secrets set --app <app> NAME=value` (NEVER in fly.toml)
#   [CONFIG]  -> non-secret; lives in fly.toml [env]
#   [FAIL-STOP] -> the API refuses to boot outside development if missing/invalid
#
# All facts below were confirmed against services/api/internal/config/config.go
# and a prod-mode container run.
# =============================================================================


# -----------------------------------------------------------------------------
# Core
# -----------------------------------------------------------------------------
# [CONFIG] Selects production validation (https-only CORS, RLS-required DB
#          pool). MUST be exactly "production" in prod. Source: fly.toml [env].
NODE_ENV=production

# [CONFIG] Listener. API_HOST=0.0.0.0 binds all interfaces; API_PORT must match
#          fly.toml internal_port (8080) and the Dockerfile EXPOSE. Source: fly.toml [env].
API_HOST=0.0.0.0
API_PORT=8080

# [CONFIG] Logging. Source: fly.toml [env].
API_LOG_LEVEL=info
API_LOG_FORMAT=json

# [CONFIG] [FAIL-STOP outside dev] CORS allow-list. Comma-separated. Every entry
#          MUST be an explicit https:// origin (no "*", no http://) or the API
#          refuses to boot. Set to the WEB app's public origin(s).
#          Source: fly.toml [env]. Example:
API_CORS_ALLOWED_ORIGINS=https://app.fuelgrid.example,https://fuelgrid-web.fly.dev

# [CONFIG] Number of trusted reverse-proxy hops in front of the API. Fly edge =
#          1 hop, so set 1 to read the real client IP (AUTH-09). Source: fly.toml [env].
API_TRUSTED_PROXY_DEPTH=1

# [CONFIG] Graceful shutdown budget. Source: fly.toml [env] (or leave default 15s).
API_SHUTDOWN_TIMEOUT=15s


# -----------------------------------------------------------------------------
# Database (Postgres) — managed Fly Postgres or external (sslmode=require)
# -----------------------------------------------------------------------------
# [SECRET] OWNER DSN. Used for MIGRATIONS ONLY (the CD migrate job runs
#          golang-migrate up as the owner). Embeds the owner password.
#          sslmode=require for managed/remote Postgres. Source: GitHub Actions
#          secret DATABASE_URL (for CD migrate) AND `fly secrets set` if you
#          ever run owner-scoped tooling on the machine. Example:
DATABASE_URL=postgres://fuelgrid_owner:OWNER_PASSWORD@<pg-host>:5432/fuelgrid?sslmode=require

# [SECRET] [FAIL-STOP outside dev when DATABASE_URL set] NON-OWNER DSN. The
#          running API uses this for ALL request-scoped queries so Postgres RLS
#          enforces tenant isolation (INFRA-01/AUTH-25). MUST be the
#          `fuelgrid_app` role (created by migration 0005_rls.up.sql) and MUST
#          be DISTINCT from DATABASE_URL. The migration creates the role; the
#          OPERATOR sets its password and builds this DSN from it.
#          Source: `fly secrets set --app fuelgrid-api`. Example:
DATABASE_APP_URL=postgres://fuelgrid_app:APP_ROLE_PASSWORD@<pg-host>:5432/fuelgrid?sslmode=require

# [CONFIG] Pool tuning (non-secret). Source: fly.toml [env] or leave defaults.
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MIN_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m


# -----------------------------------------------------------------------------
# Redis — Upstash add-on or Fly Redis app
# -----------------------------------------------------------------------------
# [SECRET] Connection URL (embeds password). Used for sessions, rate limiting,
#          login throttling. /readyz pings it. Use rediss:// (TLS) for Upstash.
#          Source: `fly secrets set --app fuelgrid-api`. Example:
REDIS_URL=rediss://default:REDIS_PASSWORD@<redis-host>:6379/0


# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# [SECRET] [FAIL-STOP outside dev] Pepper mixed (HMAC-SHA256) into every
#          argon2id password hash. Generate once: `openssl rand -base64 32`.
#          ROTATION INVALIDATES ALL EXISTING PASSWORD HASHES — rotating forces
#          a password-reset wave for every user. Treat as permanent.
#          Source: `fly secrets set --app fuelgrid-api`.
AUTH_PASSWORD_PEPPER=

# [CONFIG] Session/lockout tuning (non-secret). Source: fly.toml [env] or defaults.
AUTH_SESSION_TTL=12h
AUTH_REFRESH_TTL=720h
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW=15m
AUTH_LOGIN_LOCK_AFTER=10
AUTH_LOGIN_LOCK_FOR=30m
AUTH_PASSWORD_RESET_TTL=1h

# [SECRET] Platform-admin bearer for POST /api/v1/platform/tenants (tenant
#          provisioning / IaC). Blank DISABLES the route. Set to a long random
#          token in prod. Source: `fly secrets set --app fuelgrid-api`.
PLATFORM_ADMIN_TOKEN=


# -----------------------------------------------------------------------------
# Transactional email (SMTP) — optional; console no-op driver when SMTP_HOST blank
# -----------------------------------------------------------------------------
# [CONFIG] SMTP host/port/username/from. Source: fly.toml [env].
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
# [SECRET] SMTP password. Source: `fly secrets set --app fuelgrid-api`.
SMTP_PASSWORD=
# [CONFIG] Envelope From and public web origin used to build email links
#          (e.g. password-reset URLs). Set APP_BASE_URL to the WEB public origin.
SMTP_FROM=no-reply@fuelgrid.example
APP_BASE_URL=https://app.fuelgrid.example

# [CONFIG] Canned scheduled report digests (daily station-close + monthly P&L).
#          No-op unless enabled AND real SMTP AND recipients set. Source: fly.toml [env].
REPORT_DIGEST_ENABLED=false
REPORT_DIGEST_RECIPIENTS=
REPORT_DIGEST_SEND_HOUR=6


# -----------------------------------------------------------------------------
# M-Pesa (Safaricom Daraja) — optional; disabled no-op (503) when keys unset
# -----------------------------------------------------------------------------
# [SECRET] Daraja API credentials. Source: `fly secrets set --app fuelgrid-api`.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
# [CONFIG] Environment selector (sandbox|production). Source: fly.toml [env].
MPESA_ENV=production
# [CONFIG] Shortcode + STK callback URL (non-secret). Source: fly.toml [env].
MPESA_SHORTCODE=
MPESA_CALLBACK_URL=https://api.fuelgrid.example/api/v1/payments/mpesa/callback


# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
# [CONFIG] Outbox-lag metric refresh cadence. Source: fly.toml [env] / default.
METRICS_OBSERVE_INTERVAL=15s

# [CONFIG] [FAIL-STOP when OTEL_EXPORTER=otlp] Tracing exporter: none|stdout|otlp.
#          When "otlp", OTEL_EXPORTER_OTLP_ENDPOINT MUST be a reachable
#          collector (bare host:port or https:// = TLS; http:// = insecure) or
#          the API refuses to boot (no silent trace loss). Keep "none" until a
#          collector exists. OTEL_EXPORTER/OTEL_SERVICE_NAME are [CONFIG]
#          (fly.toml [env]); the endpoint is environment-specific —
OTEL_EXPORTER=none
OTEL_SERVICE_NAME=fuelgrid-api
# [SECRET-ish] Collector endpoint (may embed auth in some collectors). Set via
#          `fly secrets set` if it carries a token, else fly.toml [env]. Example:
OTEL_EXPORTER_OTLP_ENDPOINT=

# [SECRET] Sentry DSN (treat as secret — it authorizes event ingestion). Blank
#          disables Sentry. Source: `fly secrets set --app fuelgrid-api`.
SENTRY_DSN=
# [CONFIG] Fraction of transactions traced — keep tiny in prod. Source: fly.toml [env].
SENTRY_TRACES_SAMPLE_RATE=0.05


# =============================================================================
# WEB app (apps/web) — set on the fuelgrid-web Fly app
# =============================================================================
# [CONFIG] Server-side upstream the BFF proxy forwards to (api-origin.ts reads
#          API_ORIGIN first). Point at the API app. Source: apps/web/fly.toml [env].
#          On Fly private network: http://fuelgrid-api.internal:8080
API_ORIGIN=http://fuelgrid-api.internal:8080
# [CONFIG] Web listen port (matches fly.toml internal_port 3000). Source: fly.toml [env].
PORT=3000
# [CONFIG] Public, build/runtime-visible (NEXT_PUBLIC_*). NON-secret by design.
NEXT_PUBLIC_APP_NAME=FuelGrid OS
NEXT_PUBLIC_APP_ENV=production
# [SECRET-ish] Browser Sentry DSN (public but environment-specific).
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05


# =============================================================================
# GitHub Actions CD secrets (Settings -> Secrets and variables -> Actions,
# or scoped to the `production` Environment) — NOT app runtime env:
#   DATABASE_URL        [SECRET] owner DSN for the migrate job (sslmode=require)
#   DEPLOY_HEALTH_URL   [SECRET] full https URL of deployed /readyz for the smoke gate
#   FLY_API_TOKEN       [SECRET] `fly tokens create deploy` — gates the flyctl rollout
# When any are unset the corresponding CD job is a clean no-op (::notice:: + skip).
# =============================================================================
