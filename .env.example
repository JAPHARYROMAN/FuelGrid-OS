# =============================================================================
# FuelGrid OS — Example environment file
# =============================================================================
# Copy to `.env` (gitignored) and fill in real values for local development.
# Production values are managed by the deployment platform's secret store.
#
# Each variable lists the stage that introduces it. Stages not yet
# implemented have placeholder entries so we know the slot exists.
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1 — Tooling
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Stage 2 — API service (services/api)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
API_LOG_LEVEL=debug
API_LOG_FORMAT=json
# Comma-separated list of allowed CORS origins
API_CORS_ALLOWED_ORIGINS=http://localhost:3000
API_SHUTDOWN_TIMEOUT=15s

# -----------------------------------------------------------------------------
# Stage 3 — Database & Redis
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://fuelgrid:fuelgrid@localhost:5432/fuelgrid?sslmode=disable
# DATABASE_APP_URL: connect request-scoped queries as the non-owner fuelgrid_app
# role so Postgres row-level security enforces tenant isolation per request.
# Leave unset to connect as the owner (RLS bypassed). The fuelgrid_app role is
# created by migration 0005 with a default password — rotate it via your secret
# store. Example:
# DATABASE_APP_URL=postgres://fuelgrid_app:CHANGE_ME@localhost:5432/fuelgrid?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MIN_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=30m
DATABASE_CONN_MAX_IDLE_TIME=5m

REDIS_URL=redis://localhost:6379/0

# Override the migrations directory the migrate command uses. The default
# resolves to <repo>/services/api/migrations.
MIGRATIONS_PATH=

# -----------------------------------------------------------------------------
# Stage 4 — Auth
# -----------------------------------------------------------------------------
# Secret mixed into every argon2id password hash via HMAC-SHA256. Rotate
# carefully — changing this invalidates all existing password hashes.
# Empty value is allowed in development.
AUTH_PASSWORD_PEPPER=
AUTH_SESSION_TTL=12h
AUTH_REFRESH_TTL=720h
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW=15m
AUTH_LOGIN_LOCK_AFTER=10
AUTH_LOGIN_LOCK_FOR=30m
AUTH_PASSWORD_RESET_TTL=1h

# Email delivery for password reset / invites
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=no-reply@fuelgrid.local

# Demo user credentials used by `make seed`. Override per developer.
DEMO_TENANT_SLUG=demo
DEMO_USER_EMAIL=demo@fuelgrid.local
DEMO_USER_PASSWORD=fuelgrid-demo-password-1234

# Platform-admin bearer for POST /api/v1/platform/tenants (tenant
# provisioning). Blank disables the route entirely. Set to a long random
# secret in production; rotate via secret store.
PLATFORM_ADMIN_TOKEN=

# -----------------------------------------------------------------------------
# Stage 7 — Event publisher
# -----------------------------------------------------------------------------
OUTBOX_POLL_INTERVAL=2s
OUTBOX_BATCH_SIZE=100

# -----------------------------------------------------------------------------
# Stage 8 — Web app (apps/web)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=FuelGrid OS

# -----------------------------------------------------------------------------
# Stage 10 — Observability (optional)
# -----------------------------------------------------------------------------
# /metrics is always served. METRICS_OBSERVE_INTERVAL controls the cadence
# of the outbox-lag refresh worker.
METRICS_OBSERVE_INTERVAL=15s

# OTel exporter: none | stdout. "otlp" is reserved for when a real
# collector is in front of the API.
OTEL_EXPORTER=none
OTEL_SERVICE_NAME=fuelgrid-api

# Sentry: blank DSN disables. TRACES_SAMPLE_RATE is fraction of
# transactions Sentry traces — keep tiny in prod.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
