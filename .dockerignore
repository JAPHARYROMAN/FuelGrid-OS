# Build context hygiene — keep the layer that COPY's into the builder small.

.git
.github
.husky
.vscode
.idea
.DS_Store
Thumbs.db

node_modules
**/node_modules
.next
**/.next
.turbo
**/.turbo
coverage
**/coverage
dist
**/dist
build
**/build
bin
**/bin

# The API build (services/api/Dockerfile) does not need apps/, but the web
# build (apps/web/Dockerfile) does — both use the repo root as context. Ignore
# everything under apps/ EXCEPT the web app source the web image compiles.
# (node_modules/.next/coverage are already pruned by the **/ rules above.)
apps/*
!apps/web
docs
.env
.env.*
!.env.example
*.log
*.md
