{
  "__comment": "FuelGrid OS — API & platform overview. Import into Grafana (Dashboards > Import). Expects a Prometheus datasource variable ${DS_PROMETHEUS}. Metric names match internal/observability/metrics.go.",
  "title": "FuelGrid OS — API Overview",
  "uid": "fuelgrid-api-overview",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["fuelgrid", "api", "slo"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "job",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(fuelgrid_http_requests_total, job)",
        "refresh": 1,
        "current": { "text": "fuelgrid-api", "value": "fuelgrid-api" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request rate (req/s by status class)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum by (status) (rate(fuelgrid_http_requests_total{job=\"$job\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx ratio %)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.02 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(rate(fuelgrid_http_requests_total{job=\"$job\", status=~\"5..\"}[5m])) / sum(rate(fuelgrid_http_requests_total{job=\"$job\"}[5m]))",
          "legendFormat": "5xx ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(fuelgrid_http_request_duration_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(fuelgrid_http_request_duration_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(fuelgrid_http_request_duration_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 4,
      "title": "In-flight requests",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(fuelgrid_http_requests_inflight{job=\"$job\"})",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "DB connection pool (acquired / max)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "description": "Requires the pgx pool stats collector to be registered. See slo.md.",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(pgxpool_acquired_conns{job=\"$job\"})",
          "legendFormat": "acquired",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(pgxpool_max_conns{job=\"$job\"})",
          "legendFormat": "max",
          "refId": "B"
        }
      ]
    },
    {
      "id": 6,
      "title": "Outbox backlog & lag",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "fuelgrid_outbox_unpublished_events{job=\"$job\"}",
          "legendFormat": "unpublished events",
          "refId": "A"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "fuelgrid_outbox_oldest_unpublished_age_seconds{job=\"$job\"}",
          "legendFormat": "oldest age (s)",
          "refId": "B"
        }
      ]
    }
  ]
}
