{
  "__comment": "FuelGrid OS — background scheduler jobs. Provisioned automatically; datasource fixed to the 'prometheus' uid. Metric names match internal/observability/metrics.go (fuelgrid_scheduler_*).",
  "title": "FuelGrid OS — Scheduler",
  "uid": "fuelgrid-scheduler",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["fuelgrid", "scheduler", "jobs"],
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(fuelgrid_scheduler_job_runs_total, job)",
        "refresh": 1,
        "current": { "text": "fuelgrid-api", "value": "fuelgrid-api" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Job run rate by result (runs/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (result) (rate(fuelgrid_scheduler_job_runs_total{job=\"$job\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Failure ratio by job",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (exported_job) (rate(fuelgrid_scheduler_job_runs_total{job=\"$job\", result=\"failure\"}[15m])) / clamp_min(sum by (exported_job) (rate(fuelgrid_scheduler_job_runs_total{job=\"$job\"}[15m])), 0.0001)",
          "legendFormat": "{{exported_job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Successful runs by job (per hour)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (exported_job) (rate(fuelgrid_scheduler_job_runs_total{job=\"$job\", result=\"success\"}[5m])) * 3600",
          "legendFormat": "{{exported_job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Failed runs by job (per hour)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (exported_job) (rate(fuelgrid_scheduler_job_runs_total{job=\"$job\", result=\"failure\"}[5m])) * 3600",
          "legendFormat": "{{exported_job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Job duration p95 by job",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, exported_job) (rate(fuelgrid_scheduler_job_duration_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "{{exported_job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Job duration p99 by job",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le, exported_job) (rate(fuelgrid_scheduler_job_duration_seconds_bucket{job=\"$job\"}[5m])))",
          "legendFormat": "{{exported_job}}",
          "refId": "A"
        }
      ]
    }
  ]
}
