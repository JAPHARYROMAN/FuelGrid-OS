{
  "__comment": "FuelGrid OS — business/operational signals. Provisioned automatically; datasource fixed to the 'prometheus' uid. Metric names match internal/observability/metrics.go.",
  "title": "FuelGrid OS — Business",
  "uid": "fuelgrid-business",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["fuelgrid", "business", "outbox"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(fuelgrid_outbox_unpublished_events, job)",
        "refresh": 1,
        "current": { "text": "fuelgrid-api", "value": "fuelgrid-api" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Outbox unpublished events (backlog)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 500 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "fuelgrid_outbox_unpublished_events{job=\"$job\"}",
          "legendFormat": "unpublished",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Outbox oldest unpublished age",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 300 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "fuelgrid_outbox_oldest_unpublished_age_seconds{job=\"$job\"}",
          "legendFormat": "oldest age",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Outbox dead-lettered events",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "fuelgrid_outbox_dead_lettered_events{job=\"$job\"}",
          "legendFormat": "dead-lettered",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Open shifts",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "fuelgrid_shifts_open{job=\"$job\"}",
          "legendFormat": "open shifts",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Posted journal entries",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "fuelgrid_accounting_journal_entries_posted{job=\"$job\"}",
          "legendFormat": "posted journal entries",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Journal entries posted rate (per min)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(fuelgrid_accounting_journal_entries_posted{job=\"$job\"}[5m]) * 60",
          "legendFormat": "posted / min",
          "refId": "A"
        }
      ]
    }
  ]
}
